{
  "Application": {
    "Name": "Code OCR"
  },
  "ImageUpload": {
    "MaximumFileSizeBytes": 10485760,
    "AllowedExtensions": [
      ".jpg",
      ".jpeg",
      ".png",
      ".webp"
    ],
    "AllowedContentTypes": [
      "image/jpeg",
      "image/png",
      "image/webp"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "CodeOcr.Api": "Information"
    }
  },
  "AllowedHosts": "*"
}
